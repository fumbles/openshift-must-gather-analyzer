#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: analyze-mg <must-gather-path> [output-dir]

Generate a static HTML site report for an unpacked must-gather directory.
When no output directory is provided, the default is created beside the must-gather:
  must-gather-analyze.<timestamp-from-must-gather-name>

Examples:
  analyze-mg ./must-gather.local.customer.1234
  analyze-mg ./must-gather.local.customer.1234 report-site
EOF
}

strip_known_suffixes() {
  local name="$1"
  name="${name%.tar.gz}"
  name="${name%.tgz}"
  name="${name%.tar}"
  name="${name%_unpack}"
  printf '%s\n' "$name"
}

default_output_dir() {
  local input_path="$1"
  local basename output_name trimmed

  basename="$(basename "$input_path")"
  trimmed="$(strip_known_suffixes "$basename")"

  if [[ "$trimmed" =~ ^must-gather-([0-9]{2})-([0-9]{2})-([0-9]{4})-([0-9]{2})-([0-9]{2})-([0-9]{2})(-.+)?$ ]]; then
    output_name="$(printf 'must-gather-analyze.%s%s%s-%s%s%s' \
      "${BASH_REMATCH[3]}" "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" \
      "${BASH_REMATCH[4]}" "${BASH_REMATCH[5]}" "${BASH_REMATCH[6]}")"
  elif [[ "$trimmed" =~ ^must-gather-([0-9]{8})-([0-9]{6})$ ]]; then
    output_name="$(printf 'must-gather-analyze.%s-%s' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}")"
  else
    output_name='must-gather-analyze.output'
  fi

  printf '%s/%s\n' "$(dirname "$input_path")" "$output_name"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 1
fi

must_gather_path="$1"
output_path="${2:-$(default_output_dir "$must_gather_path")}"

if [[ ! -e "$must_gather_path" ]]; then
  echo "analyze-mg: path not found: $must_gather_path" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
binary_name=""

if [[ -f "$script_dir/Cargo.toml" ]]; then
  binary_name="$(sed -n 's/^name = "\(.*\)"/\1/p' "$script_dir/Cargo.toml" | head -n1)"
fi

if [[ -f "$script_dir/Cargo.toml" ]] && command -v cargo >/dev/null 2>&1; then
  cargo run --manifest-path "$script_dir/Cargo.toml" -- "$must_gather_path" "$output_path" 2>/dev/null
  echo "Wrote HTML site to $output_path/index.html"
  exit 0
fi

binary_path=""

if [[ -n "$binary_name" && -x "$script_dir/$binary_name" ]]; then
  binary_path="$script_dir/$binary_name"
elif [[ -n "$binary_name" && -x "$script_dir/target/debug/$binary_name" ]]; then
  binary_path="$script_dir/target/debug/$binary_name"
elif [[ -n "$binary_name" && -x "$script_dir/target/release/$binary_name" ]]; then
  binary_path="$script_dir/target/release/$binary_name"
else
  while IFS= read -r candidate; do
    candidate_name="$(basename "$candidate")"
    if [[ "$candidate_name" == "analyze-mg" || "$candidate_name" == "build-dist" || "$candidate_name" == "build-release-artifacts" ]]; then
      continue
    fi
    binary_path="$candidate"
    break
  done < <(find "$script_dir" -maxdepth 1 -type f -perm -111 | sort)
fi

if [[ -n "$binary_path" ]]; then
  "$binary_path" "$must_gather_path" "$output_path" 2>/dev/null
  echo "Wrote HTML site to $output_path/index.html"
  exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
  if [[ -n "$binary_name" ]]; then
    echo "analyze-mg: neither a $binary_name binary nor cargo was found" >&2
  else
    echo "analyze-mg: neither a bundled binary nor cargo was found" >&2
  fi
  exit 1
fi

cargo run --release --manifest-path "$script_dir/Cargo.toml" -- "$must_gather_path" "$output_path" 2>/dev/null

echo "Wrote HTML site to $output_path/index.html"
